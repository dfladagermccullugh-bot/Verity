# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Postgres (Neon or Supabase pooled connection string)
DATABASE_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
DAVIN_EMAIL=

# Admin
ADMIN_PASSWORD=

# Secrets (use long random strings; SESSION_COOKIE_SECRET must be >= 32 chars)
